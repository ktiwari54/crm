# Copy to apps/api/.env and fill in. Do NOT commit the real .env.

# Database (local docker compose default shown)
DATABASE_URL=postgresql://crm:crm_dev_password@localhost:5432/crm?schema=public

# Auth — CHANGE THIS in any real environment
JWT_SECRET=change_me_in_production
PORT=4000

# S3 / MinIO document storage (optional)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=crm_minio
S3_SECRET_KEY=crm_minio_password
S3_BUCKET=crm-documents
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Elasticsearch global search (optional)
ELASTICSEARCH_URL=http://localhost:9200

# Stripe payments (optional — manual payments work without these)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Subscription billing cron runs daily at 02:00; set true to disable
# BILLING_CRON_DISABLED=false

# LLM for Copilot + agents (optional)
# LLM_API_KEY=sk-...
# LLM_API_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
