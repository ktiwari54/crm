// ─── Core Entities ───────────────────────────────────────────────────────────

model Territory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users            User[]
  accounts         Account[]
  leads            Lead[]
  assignmentRules  AssignmentRule[]

  @@map("territories")
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  role         UserRole @default(rep)
  territoryId  String?  @map("territory_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  territory              Territory?              @relation(fields: [territoryId], references: [id])
  ownedAccounts          Account[]               @relation("AccountOwner")
  createdAccounts        Account[]               @relation("AccountCreator")
  updatedAccounts        Account[]               @relation("AccountUpdater")
  ownedLeads             Lead[]
  ownedDeals             Deal[]
  ownedQuotes            Quote[]
  ownedActivities        Activity[]
  emails                 Email[]
  auditLogs              AuditLog[]
  assignmentRuleMembers  AssignmentRuleMember[]
  ownedOrders            Order[]
  ownedContracts         Contract[]
  approvalRequests       ApprovalRequest[]      @relation("ApprovalRequester")
  approvalReviews        ApprovalRequest[]      @relation("ApprovalReviewer")
  dealStageChanges       DealStageHistory[]
  dealTeamMemberships    DealTeamMember[]
  cadenceEnrollments     CadenceEnrollment[]
  forecastEntries        ForecastEntry[]
  forecastAdjustments    ForecastEntry[]        @relation("ForecastAdjuster")
  uploadedDocuments      Document[]
  fieldHistoryChanges    FieldHistory[]
  feedPosts              FeedPost[]
  ownedCampaigns         MarketingCampaign[]
  authoredArticles       KnowledgeArticle[]
  dealRegistrations      DealRegistration[]     @relation("DealRegistrant")
  reviewedRegistrations  DealRegistration[]     @relation("DealRegistrationReviewer")
  ownedAccountPlans      AccountPlan[]
  ownedPlanGoals         AccountPlanGoal[]
  ownedCases             ServiceCase[]
  copilotSessions        CopilotSession[]
  mdfRequests            MdfRequest[]           @relation("MdfRequester")
  reviewedMdfRequests    MdfRequest[]           @relation("MdfReviewer")
  ownedIncidents         Incident[]
  ownedJourneys          CustomerJourney[]
  assignedWorkOrders     FieldWorkOrder[]       @relation("WorkOrderTechnician")
  gdprRequests           GdprRequest[]          @relation("GdprRequester")
  ownedSalesPrograms     SalesProgram[]
  routingRuleMemberships RoutingRuleMember[]
  ownedAgents            Agent[]              @relation("AgentOwner")
  triggeredAgentRuns     AgentRun[]           @relation("AgentRunTrigger")
  stockMovements         StockMovement[]
  payments               Payment[]
  ownedSubscriptions     Subscription[]
  revertedAuditLogs      AuditLog[]             @relation("AuditLogReverter")
  aiAuditLogs            AiAuditLog[]         @relation("AiAuditUser")
  gamificationScores     GamificationScore[]  @relation("GamificationUser")

  @@map("users")
}

model PriceBook {
  id              String     @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  currency        String     @default("USD") @db.Char(3)
  isActive        Boolean    @default(true) @map("is_active")
  isDefault       Boolean    @default(false) @map("is_default")
  erpExternalId   String?    @unique @map("erp_external_id")
  syncStatus      SyncStatus @default(pending) @map("sync_status")
  lastSyncedAt    DateTime?  @map("last_synced_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  accounts  Account[]
  entries   PriceBookEntry[]
  quotes    Quote[]

  @@map("price_books")
}

model Account {
  id              String       @id @default(uuid()) @db.Uuid
  erpExternalId   String?      @unique @map("erp_external_id")
  name            String
  accountType     AccountType  @default(customer) @map("account_type")
  parentAccountId String?      @map("parent_account_id") @db.Uuid
  ownerId         String?      @map("owner_id") @db.Uuid
  territoryId     String?      @map("territory_id") @db.Uuid
  priceBookId     String?      @map("price_book_id") @db.Uuid
  taxId           String?      @map("tax_id")
  creditLimit     Decimal?     @map("credit_limit") @db.Decimal(18, 2)
  paymentTerms    String?      @map("payment_terms")
  currency        String       @default("USD") @db.Char(3)
  billingAddress  Json?        @map("billing_address")
  shippingAddress Json?        @map("shipping_address")
  country         String?
  vatNumber       String?      @map("vat_number")
  gstNumber       String?      @map("gst_number")
  tradeLicenseNumber String?   @map("trade_license_number")
  registrationNumber String?   @map("registration_number")
  email           String?
  phone           String?
  website         String?
  industry        String?
  healthScore     HealthScore? @map("health_score")
  syncStatus      SyncStatus   @default(pending) @map("sync_status")
  lastSyncedAt    DateTime?    @map("last_synced_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  deletedAt       DateTime?    @map("deleted_at")
  createdById     String?      @map("created_by") @db.Uuid
  updatedById     String?      @map("updated_by") @db.Uuid

  parentAccount   Account?   @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts   Account[]  @relation("AccountHierarchy")
  owner           User?      @relation("AccountOwner", fields: [ownerId], references: [id])
  territory       Territory? @relation(fields: [territoryId], references: [id])
  priceBook       PriceBook? @relation(fields: [priceBookId], references: [id])
  createdBy       User?      @relation("AccountCreator", fields: [createdById], references: [id])
  updatedBy       User?      @relation("AccountUpdater", fields: [updatedById], references: [id])
  contacts        Contact[]
  deals           Deal[]
  quotes          Quote[]
  convertedLeads  Lead[]     @relation("LeadConvertedAccount")
  orders          Order[]
  invoices        Invoice[]
  contracts           Contract[]
  documents           Document[]
  campaignMembers     CampaignMember[]
  dealRegistrations   DealRegistration[]
  portalAccess        PortalAccess[]
  accountPlans        AccountPlan[]
  serviceCases        ServiceCase[]
  installedAssets     InstalledAsset[]
  rmaRequests         RmaRequest[]
  mdfRequests            MdfRequest[]
  incidentAccounts       IncidentAccount[]
  journeyEnrollments     JourneyEnrollment[]
  enablementPaths        EnablementPath[]
  enablementEnrollments  EnablementEnrollment[]
  fieldWorkOrders        FieldWorkOrder[]
  erpEvents              ErpEvent[]
  subscriptions          Subscription[]

  @@index([name])
  @@map("accounts")
}

model Contact {
  id              String     @id @default(uuid()) @db.Uuid
  erpExternalId   String?    @unique @map("erp_external_id")
  accountId       String     @map("account_id") @db.Uuid
  firstName       String     @map("first_name")
  lastName        String     @map("last_name")
  email           String?
  phone           String?
  mobile          String?
  title           String?
  department      String?
  address         Json?
  country         String?
  isPrimary       Boolean    @default(false) @map("is_primary")
  isActive        Boolean    @default(true) @map("is_active")
  syncStatus      SyncStatus @default(pending) @map("sync_status")
  lastSyncedAt    DateTime?  @map("last_synced_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  account          Account       @relation(fields: [accountId], references: [id])
  dealContacts     DealContact[]
  convertedLeads   Lead[]        @relation("LeadConvertedContact")
  serviceCases     ServiceCase[]
  gdprRequests     GdprRequest[]
  documents        Document[]

  @@map("contacts")
}

model Lead {
  id                  String     @id @default(uuid()) @db.Uuid
  companyName         String     @map("company_name")
  firstName           String?    @map("first_name")
  lastName            String?    @map("last_name")
  email               String?
  phone               String?
  title               String?
  source              LeadSource @default(other)
  status              LeadStatus @default(new)
  score               Int        @default(0)
  rating              LeadRating @default(cold)
  scoredAt            DateTime?  @map("scored_at")
  ownerId             String?    @map("owner_id") @db.Uuid
  territoryId         String?    @map("territory_id") @db.Uuid
  description         String?
  convertedAccountId  String?    @map("converted_account_id") @db.Uuid
  convertedContactId  String?    @map("converted_contact_id") @db.Uuid
  convertedDealId     String?    @map("converted_deal_id") @db.Uuid
  convertedAt         DateTime?  @map("converted_at")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")
  deletedAt           DateTime?  @map("deleted_at")

  owner              User?      @relation(fields: [ownerId], references: [id])
  territory          Territory? @relation(fields: [territoryId], references: [id])
  convertedAccount   Account?   @relation("LeadConvertedAccount", fields: [convertedAccountId], references: [id])
  convertedContact   Contact?   @relation("LeadConvertedContact", fields: [convertedContactId], references: [id])
  convertedDeal      Deal?      @relation("LeadConvertedDeal", fields: [convertedDealId], references: [id])
  sourceDeals        Deal[]     @relation("DealSourceLead")
  documents          Document[]

  @@map("leads")
}

model Pipeline {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stages PipelineStage[]

  @@map("pipelines")
}

model PipelineStage {
  id                  String   @id @default(uuid()) @db.Uuid
  pipelineId          String   @map("pipeline_id") @db.Uuid
  name                String
  sortOrder           Int      @map("sort_order")
  defaultProbability  Int      @map("default_probability")
  isClosed            Boolean  @default(false) @map("is_closed")
  isWon               Boolean  @default(false) @map("is_won")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  pipeline       Pipeline        @relation(fields: [pipelineId], references: [id])
  deals          Deal[]
  blueprintRules BlueprintRule[]

  @@map("pipeline_stages")
}

model Deal {
  id                String    @id @default(uuid()) @db.Uuid
  name              String
  accountId         String    @map("account_id") @db.Uuid
  ownerId           String?   @map("owner_id") @db.Uuid
  pipelineStageId   String    @map("pipeline_stage_id") @db.Uuid
  amount            Decimal?  @db.Decimal(18, 2)
  probability       Int?
  expectedCloseDate DateTime? @map("expected_close_date") @db.Date
  actualCloseDate   DateTime? @map("actual_close_date") @db.Date
  closeReason       String?   @map("close_reason")
  sourceLeadId      String?           @map("source_lead_id") @db.Uuid
  primaryQuoteId    String?           @unique @map("primary_quote_id") @db.Uuid
  forecastCategory  ForecastCategory? @map("forecast_category")
  description       String?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")

  account        Account            @relation(fields: [accountId], references: [id])
  owner          User?              @relation(fields: [ownerId], references: [id])
  pipelineStage  PipelineStage      @relation(fields: [pipelineStageId], references: [id])
  sourceLead     Lead?              @relation("DealSourceLead", fields: [sourceLeadId], references: [id])
  primaryQuote   Quote?             @relation("DealPrimaryQuote", fields: [primaryQuoteId], references: [id])
  quotes         Quote[]            @relation("DealQuotes")
  dealContacts   DealContact[]
  convertedLeads Lead[]             @relation("LeadConvertedDeal")
  orders         Order[]
  contracts      Contract[]
  stageHistory   DealStageHistory[]
  teamMembers    DealTeamMember[]
  forecastEntries ForecastEntry[]
  documents      Document[]

  @@index([accountId])
  @@index([pipelineStageId])
  @@index([ownerId])
  @@map("deals")
}

model DealContact {
  id        String      @id @default(uuid()) @db.Uuid
  dealId    String      @map("deal_id") @db.Uuid
  contactId String      @map("contact_id") @db.Uuid
  role      ContactRole @default(other)
  isPrimary Boolean     @default(false) @map("is_primary")
  createdAt DateTime    @default(now()) @map("created_at")

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id])

  @@unique([dealId, contactId])
  @@map("deal_contacts")
}

model ProductCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  parentId  String?  @map("parent_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent   ProductCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children ProductCategory[] @relation("CategoryHierarchy")
  products Product[]

  @@map("product_categories")
}

model Product {
  id                     String     @id @default(uuid()) @db.Uuid
  erpExternalId          String?    @unique @map("erp_external_id")
  sku                    String     @unique
  manufacturerPartNumber String?    @map("manufacturer_part_number")
  upcEan                 String?    @map("upc_ean")
  name                   String
  description            String?
  manufacturer           String?
  categoryId             String?    @map("category_id") @db.Uuid
  unitOfMeasure          String?    @map("unit_of_measure")
  listPrice              Decimal?   @map("list_price") @db.Decimal(18, 4)
  costPrice              Decimal?   @map("cost_price") @db.Decimal(18, 4)
  weight                 Json?
  dimensions             Json?
  attributes             Json?
  imageUrl               String?    @map("image_url")
  datasheetUrl           String?    @map("datasheet_url")
  isActive               Boolean    @default(true) @map("is_active")
  isEol                  Boolean    @default(false) @map("is_eol")
  eolDate                DateTime?  @map("eol_date") @db.Date
  successorProductId     String?    @map("successor_product_id") @db.Uuid
  eccn                   String?
  exportRestrictedCountries Json?   @map("export_restricted_countries")
  syncStatus             SyncStatus @default(pending) @map("sync_status")
  lastSyncedAt           DateTime?  @map("last_synced_at")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")
  deletedAt              DateTime?  @map("deleted_at")

  category           ProductCategory?  @relation(fields: [categoryId], references: [id])
  successorProduct   Product?          @relation("ProductSuccessor", fields: [successorProductId], references: [id])
  predecessorProducts Product[]        @relation("ProductSuccessor")
  relationsFrom      ProductRelation[] @relation("ProductFrom")
  relationsTo        ProductRelation[] @relation("ProductTo")
  inventoryLevels    InventoryLevel[]
  priceBookEntries   PriceBookEntry[]
  quoteLineItems     QuoteLineItem[]
  orderLineItems     OrderLineItem[]
  constraintsFrom    ProductConstraint[] @relation("ConstraintProduct")
  constraintsTo      ProductConstraint[] @relation("ConstraintRelatedProduct")
  vendorProducts     VendorProduct[]
  knowledgeArticles  KnowledgeArticle[]
  installedAssets    InstalledAsset[]
  stockMovements     StockMovement[]
  subscriptionItems  SubscriptionItem[]

  @@index([sku])
  @@index([manufacturerPartNumber])
  @@map("products")
}

model ProductRelation {
  id               String              @id @default(uuid()) @db.Uuid
  productId        String              @map("product_id") @db.Uuid
  relatedProductId String              @map("related_product_id") @db.Uuid
  relationType     ProductRelationType @map("relation_type")
  createdAt        DateTime            @default(now()) @map("created_at")

  product        Product @relation("ProductFrom", fields: [productId], references: [id], onDelete: Cascade)
  relatedProduct Product @relation("ProductTo", fields: [relatedProductId], references: [id], onDelete: Cascade)

  @@unique([productId, relatedProductId, relationType])
  @@map("product_relations")
}

model Warehouse {
  id            String   @id @default(uuid()) @db.Uuid
  erpExternalId String?  @unique @map("erp_external_id")
  name          String
  code          String   @unique
  isPrimary     Boolean  @default(false) @map("is_primary")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  inventoryLevels InventoryLevel[]
  quoteLineItems  QuoteLineItem[]
  orderLineItems  OrderLineItem[]
  stockMovements  StockMovement[]

  @@map("warehouses")
}

model InventoryLevel {
  id            String    @id @default(uuid()) @db.Uuid
  productId     String    @map("product_id") @db.Uuid
  warehouseId   String    @map("warehouse_id") @db.Uuid
  onHand        Decimal   @default(0) @map("on_hand") @db.Decimal(18, 4)
  allocated     Decimal   @default(0) @db.Decimal(18, 4)
  onOrder       Decimal   @default(0) @map("on_order") @db.Decimal(18, 4)
  inTransit     Decimal   @default(0) @map("in_transit") @db.Decimal(18, 4)
  atp           Decimal   @default(0) @db.Decimal(18, 4)
  backorderQty  Decimal   @default(0) @map("backorder_qty") @db.Decimal(18, 4)
  reorderPoint    Decimal @default(0) @map("reorder_point") @db.Decimal(18, 4)
  reorderQuantity Decimal @default(0) @map("reorder_quantity") @db.Decimal(18, 4)
  safetyStock     Decimal @default(0) @map("safety_stock") @db.Decimal(18, 4)
  lastSyncedAt  DateTime? @map("last_synced_at")
  syncEventId   String?   @map("sync_event_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  product   Product            @relation(fields: [productId], references: [id])
  warehouse Warehouse          @relation(fields: [warehouseId], references: [id])
  syncEvent IntegrationEvent?  @relation(fields: [syncEventId], references: [id])

  @@unique([productId, warehouseId])
  @@index([productId])
  @@index([warehouseId])
  @@map("inventory_levels")
}

model StockMovement {
  id           String            @id @default(uuid()) @db.Uuid
  productId    String            @map("product_id") @db.Uuid
  warehouseId  String            @map("warehouse_id") @db.Uuid
  type         StockMovementType
  quantity     Decimal           @db.Decimal(18, 4)
  balanceAfter Decimal           @map("balance_after") @db.Decimal(18, 4)
  reason       String?
  reference    String?
