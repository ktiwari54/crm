  account    Account         @relation(fields: [accountId], references: [id])
  asset      InstalledAsset? @relation(fields: [assetId], references: [id])
  technician User?           @relation("WorkOrderTechnician", fields: [technicianId], references: [id])

  @@index([status, scheduledAt])
  @@map("field_work_orders")
}

model BillingSchedule {
  id           String                @id @default(uuid()) @db.Uuid
  invoiceId    String                @map("invoice_id") @db.Uuid
  name         String
  status       BillingScheduleStatus @default(draft)
  totalAmount  Decimal               @map("total_amount") @db.Decimal(18, 2)
  erpSyncStatus String?              @map("erp_sync_status")
  erpSyncedAt  DateTime?             @map("erp_synced_at")
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  invoice      Invoice               @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  installments BillingInstallment[]

  @@index([invoiceId])
  @@map("billing_schedules")
}

model BillingInstallment {
  id                String                   @id @default(uuid()) @db.Uuid
  scheduleId        String                   @map("schedule_id") @db.Uuid
  installmentNumber Int                      @map("installment_number")
  dueDate           DateTime                 @map("due_date") @db.Date
  amount            Decimal                  @db.Decimal(18, 2)
  status            BillingInstallmentStatus @default(pending)
  paidAt            DateTime?                @map("paid_at")
  createdAt         DateTime                 @default(now()) @map("created_at")

  schedule BillingSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, installmentNumber])
  @@map("billing_installments")
}

model Subscription {
  id                 String             @id @default(uuid()) @db.Uuid
  subscriptionNumber String             @unique @map("subscription_number")
  accountId          String             @map("account_id") @db.Uuid
  contractId         String?            @map("contract_id") @db.Uuid
  ownerId            String?            @map("owner_id") @db.Uuid
  name               String
  status             SubscriptionStatus @default(active)
  interval           BillingInterval    @default(monthly)
  intervalCount      Int                @default(1) @map("interval_count")
  currency           String             @default("USD")
  startDate          DateTime           @map("start_date") @db.Date
  nextBillingDate    DateTime?          @map("next_billing_date") @db.Date
  currentPeriodEnd   DateTime?          @map("current_period_end") @db.Date
  trialEndsAt        DateTime?          @map("trial_ends_at") @db.Date
  canceledAt         DateTime?          @map("canceled_at")
  autoRenew          Boolean            @default(true) @map("auto_renew")
  notes              String?
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  deletedAt          DateTime?          @map("deleted_at")

  account  Account            @relation(fields: [accountId], references: [id])
  contract Contract?          @relation(fields: [contractId], references: [id])
  owner    User?              @relation(fields: [ownerId], references: [id])
  items    SubscriptionItem[]
  invoices Invoice[]

  @@index([accountId])
  @@index([status])
  @@index([nextBillingDate])
  @@map("subscriptions")
}

model SubscriptionItem {
  id             String   @id @default(uuid()) @db.Uuid
  subscriptionId String   @map("subscription_id") @db.Uuid
  productId      String?  @map("product_id") @db.Uuid
  description    String
  quantity       Decimal  @default(1) @db.Decimal(18, 4)
  unitPrice      Decimal  @map("unit_price") @db.Decimal(18, 4)
  createdAt      DateTime @default(now()) @map("created_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  product      Product?     @relation(fields: [productId], references: [id])

  @@index([subscriptionId])
  @@map("subscription_items")
}

// ─── Phase 6 Batch 14: Platform & Compliance ─────────────────────────────────

model GdprRequest {
  id            String            @id @default(uuid()) @db.Uuid
  requestType   GdprRequestType   @map("request_type")
  email         String
  contactId     String?           @map("contact_id") @db.Uuid
  status        GdprRequestStatus @default(pending)
  exportPayload Json?             @map("export_payload")
  notes         String?
  requestedById String?           @map("requested_by_id") @db.Uuid
  completedAt   DateTime?         @map("completed_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  contact     Contact? @relation(fields: [contactId], references: [id])
  requestedBy User?    @relation("GdprRequester", fields: [requestedById], references: [id])

  @@index([status])
  @@map("gdpr_requests")
}

model CustomModule {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  apiName     String   @unique @map("api_name")
  description String?
  schema      Json
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  records CustomModuleRecord[]

  @@map("custom_modules")
}

model CustomModuleRecord {
  id        String   @id @default(uuid()) @db.Uuid
  moduleId  String   @map("module_id") @db.Uuid
  data      Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  module CustomModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("custom_module_records")
}

model SalesProgram {
  id            String              @id @default(uuid()) @db.Uuid
  name          String
  description   String?
  productFocus  String?             @map("product_focus")
  startDate     DateTime            @map("start_date") @db.Date
  endDate       DateTime            @map("end_date") @db.Date
  targetRevenue Decimal?            @map("target_revenue") @db.Decimal(18, 2)
  targetUnits   Int?                @map("target_units")
  status        SalesProgramStatus  @default(planned)
  ownerId       String?             @map("owner_id") @db.Uuid
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  owner User? @relation(fields: [ownerId], references: [id])

  @@map("sales_programs")
}

model RoutingRule {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  entityType String   @map("entity_type")
  queue      String?
  skills     Json?
  priority   Int      @default(100)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  members RoutingRuleMember[]

  @@index([entityType, isActive])
  @@map("routing_rules")
}

model RoutingRuleMember {
  id             String    @id @default(uuid()) @db.Uuid
  ruleId         String    @map("rule_id") @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  currentLoad    Int       @default(0) @map("current_load")
  lastAssignedAt DateTime? @map("last_assigned_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  rule RoutingRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  user User        @relation(fields: [userId], references: [id])

  @@unique([ruleId, userId])
  @@map("routing_rule_members")
}

// ─── Phase 6 Batch 16: Agents & Data Platform ───────────────────────────────

model Agent {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  agentType   AgentType @map("agent_type")
  description String?
  config      Json?
  isActive    Boolean   @default(true) @map("is_active")
  ownerId     String?   @map("owner_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  owner User?      @relation("AgentOwner", fields: [ownerId], references: [id])
  runs  AgentRun[]

  @@map("agents")
}

model AgentRun {
  id            String         @id @default(uuid()) @db.Uuid
  agentId       String         @map("agent_id") @db.Uuid
  status        AgentRunStatus @default(pending)
  input         Json?
  output        Json?
  errorMessage  String?        @map("error_message")
  triggeredById String?        @map("triggered_by_id") @db.Uuid
  startedAt     DateTime?      @map("started_at")
  completedAt   DateTime?      @map("completed_at")
  createdAt     DateTime       @default(now()) @map("created_at")

  agent       Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  triggeredBy User? @relation("AgentRunTrigger", fields: [triggeredById], references: [id])

  @@index([agentId])
  @@map("agent_runs")
}

model ErpEvent {
  id          String       @id @default(uuid()) @db.Uuid
  accountId   String       @map("account_id") @db.Uuid
  eventType   ErpEventType @map("event_type")
  externalId  String?      @map("external_id")
  title       String
  description String?
  amount      Decimal?     @db.Decimal(18, 2)
  metadata    Json?
  occurredAt  DateTime     @map("occurred_at")
  syncedAt    DateTime     @default(now()) @map("synced_at")

  account Account @relation(fields: [accountId], references: [id])

  @@index([accountId, occurredAt])
  @@map("erp_events")
}

model AiAuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  action        String
  entityType    String?  @map("entity_type")
  entityId      String?  @map("entity_id") @db.Uuid
  userId        String?  @map("user_id") @db.Uuid
  model         String?
  piiMasked     Boolean  @default(true) @map("pii_masked")
  promptPreview String?  @map("prompt_preview")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation("AiAuditUser", fields: [userId], references: [id])

  @@index([createdAt])
  @@map("ai_audit_logs")
}

model GamificationScore {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  period    String
  metric    String
  points    Int      @default(0)
  rank      Int?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation("GamificationUser", fields: [userId], references: [id])

  @@unique([userId, period, metric])
  @@map("gamification_scores")
}